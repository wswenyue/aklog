# Description: a bash script

AKLOG_PYTHON=__AKLOG_PYTHON__

script_dir() {
	local src="${BASH_SOURCE[0]:-$0}"
	while [ -L "$src" ]; do
		local dir
		dir="$(cd -P "$(dirname "$src")" && pwd)"
		src="$(readlink "$src")"
		[[ "$src" != /* ]] && src="${dir}/${src}"
	done
	cd -P "$(dirname "$src")" && pwd
}

resolve_ak_dir() {
	local base
	base="$(script_dir)"
	if [ -d "${base}/src/aklog" ]; then
		echo "${base}"
		return 0
	fi
	if [ -d "${base}/../libexec/src/aklog" ]; then
		cd "${base}/../libexec" && pwd
		return 0
	fi
	echo "Failed to locate aklog package." >&2
	return 1
}

check_rich() {
	local py="$1"
	if ! "$py" -c "import rich" 2>/dev/null; then
		echo >&2 "aklog requires the 'rich' package. Install with:"
		echo >&2 "  $py -m pip install rich"
		return 1
	fi
	return 0
}

run_aklog() {
	local py="$1"
	shift
	check_rich "$py" || exit 1
	PYTHONPATH="${AK_DIR}/src" exec "$py" -m aklog "$@"
}

AK_DIR="$(resolve_ak_dir)" || exit 1

if [ "$AKLOG_PYTHON" != "__AKLOG_PYTHON__" ] && [ -x "$AKLOG_PYTHON" ]; then
	run_aklog "$AKLOG_PYTHON" "$@"
fi

if py="$(command -v python3 2>/dev/null)" && [ -x "$py" ]; then
	run_aklog "$py" "$@"
fi
if py="$(command -v python 2>/dev/null)" && [ -x "$py" ]; then
	run_aklog "$py" "$@"
fi

echo >&2 "Failed to execute, please install python before."
exit 1
